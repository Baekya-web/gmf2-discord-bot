# Discord bot credentials (server-side only; never ship to mobile clients)
DISCORD_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=

# Supabase Edge Functions used by existing /link and optional leaderboard flow
SUPABASE_REDEEM_URL=
SUPABASE_LEADERBOARD_URL=
SUPABASE_LINK_STATUS_URL=
SUPABASE_ANON_KEY=
BOT_SHARED_SECRET=

# Manual share API protection. If omitted, BOT_SHARED_SECRET is reused.
GMF_DISCORD_API_SECRET=

# Manual share HTTP API
PORT=3000

# Group routing allowlist for MVP. The app-provided resultChannelId must be listed here
# Optional default channel is treated as allowed but Step 6.2.5-B manual_apply_share payloads
# should still include resultChannelId.
DISCORD_ALLOWED_CHANNEL_IDS=111111111111111111,222222222222222222
DISCORD_DEFAULT_RESULT_CHANNEL_ID=
