# Discord bot credentials (server-side only; never ship to mobile clients)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Supabase project URL used by /link to call:
#   ${SUPABASE_URL}/functions/v1/redeem-link-code
SUPABASE_URL=

# /link -> Supabase redeem-link-code shared secret.
# This value is sent as the x-bot-secret header and must match
# Deno.env.get("BOT_SHARED_SECRET") in the Supabase Edge Function.
BOT_SHARED_SECRET=

# App/Supabase share callbacks -> bot HTTP share API, if used separately.
# This may intentionally differ from BOT_SHARED_SECRET unless your architecture
# requires the same secret for both flows.
GMF_DISCORD_BOT_SHARE_SECRET=
GMF_DISCORD_BOT_SHARE_URL=

# Optional existing flows
SUPABASE_LEADERBOARD_URL=
SUPABASE_LINK_STATUS_URL=
SUPABASE_ANON_KEY=
PORT=10000
DISCORD_ALLOWED_CHANNEL_IDS=111111111111111111,222222222222222222
DISCORD_DEFAULT_RESULT_CHANNEL_ID=
